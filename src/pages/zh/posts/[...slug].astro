---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import { baseFromFilePath, siblingUrlFor } from '../../../lib/lang';

export async function getStaticPaths() {
  const all = await getCollection('posts');
  const zhPosts = all.filter(
    (p) => p.data.lang === 'zh' && (import.meta.env.PROD ? !p.data.draft : true),
  );
  return zhPosts.map((post) => ({
    params: { slug: baseFromFilePath(post.filePath ?? '') },
    props: { post, all },
  }));
}

const { post, all } = Astro.props;
const { Content } = await render(post);
const siblingHref = siblingUrlFor(post, all);
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updated={post.data.updated}
  tags={post.data.tags}
  draft={post.data.draft}
  lang="zh"
  siblingHref={siblingHref}
>
  <Content />
</PostLayout>
